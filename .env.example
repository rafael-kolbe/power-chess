# Copy to .env and adjust. Never commit .env.
# `docker compose` loads this file for variable substitution and passes it into the server container.

SERVER_ADDR=:8080

# For `go run` on the host with Postgres from `docker compose` (port 5433 published).
# The compose file overrides DATABASE_URL inside the server container to use hostname `postgres`.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/powerchess?sslmode=disable

# Required when DATABASE_URL is set (min 16 characters).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-16-chars

# When 1, WebSocket message debug_match_fixture is accepted; Postgres room saves are skipped.
ADMIN_DEBUG_MATCH=0
