# Node / frontend tooling (lint only; image build is pure Go)
node_modules/
package.json
package-lock.json
.stylelintrc.json

# VCS and editor noise
.git
.gitignore
.cursor
.idea
.vscode

# Local env (compose injects vars; never bake secrets into context)
.env
.env.*
!.env.example

# Docs and specs not needed to compile
*.md

# Compose is not used by the Dockerfile COPY layers
docker-compose.yml
docker-compose.override.yml

# Test artifacts
test-result
test-result/
test-results/

# Local binaries and caches
bin/
dist/
tmp/
*.log
coverage.out
*.exe
**/__debug_bin

# Session + match debug logs under logs/ (e.g. logs/docker/server/*.log from compose bind mounts).
# Excluded from *docker build context* only — image COPY steps never see these paths.
# Compose still bind-mounts the repo: the server/postgres wrappers keep writing to the host tree at runtime.
logs/
logs/**

# OS cruft
.DS_Store
Thumbs.db
